# ============================================================
#  Trippa — environment variables
#  Copy to ".env" (or ".env.local" for Next.js) and fill in.
#  Any key left blank → that provider stays in MOCK mode and the
#  app keeps working with clearly-labelled demo data.
#
#  In the single-file PWA build these are injected at build time as
#  window.TRIPPA_ENV = { ... }. NEXT_PUBLIC_* keys are safe in the
#  browser; the others must stay server-side only.
# ============================================================

# ---- Supabase (auth, cloud sync, sharing) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- AI (itinerary generation, concierge) ----
OPENAI_API_KEY=

# ---- Google (maps + global place search) ----
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# ---- Flights + hotels (Travelpayouts network) ----
TRAVELPAYOUTS_API_TOKEN=
TRAVELPAYOUTS_MARKER=543809

# ---- Hotel affiliate (optional, Booking via CJ) ----
BOOKING_AFFILIATE_ID=
CJ_WEBSITE_ID=

# ---- Weather + currency (both have keyless fallbacks) ----
OPENWEATHER_API_KEY=
EXCHANGE_RATE_API_KEY=

# ---- Transactional email (reminders) ----
RESEND_API_KEY=
