# ============================================================
#  Trippa — environment variables
#  Copy to ".env.local" (git-ignored) and fill in.
#
#  Secrets are SERVER-SIDE ONLY: they are read by API routes via
#  process.env and are NEVER sent to the browser or bundled into the
#  mobile (Capacitor) app. Only NEXT_PUBLIC_* values reach the client.
#  Any key left blank → that provider stays in clearly-labelled MOCK mode
#  and the app keeps working.
# ============================================================

# ---- AI (server-side only) ----
# Used by the /api/ai route. Never exposed to the client / mobile bundle.
OPENAI_API_KEY=

# Public base URL of the deployed app/backend. The mobile build calls
# <NEXT_PUBLIC_APP_URL>/api/ai for AI. Leave blank for same-origin web.
NEXT_PUBLIC_APP_URL=

# ---- Optional AI fallbacks (server-side only) ----
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---- Supabase (auth, cloud sync) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Google (maps + global place search) ----
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# ---- Flights + hotels (Travelpayouts network) ----
TRAVELPAYOUTS_API_TOKEN=
TRAVELPAYOUTS_MARKER=543809

# ---- Hotel affiliate (optional, Booking via CJ) ----
BOOKING_AFFILIATE_ID=
CJ_WEBSITE_ID=

# ---- Weather + currency (both have keyless fallbacks) ----
OPENWEATHER_API_KEY=
EXCHANGE_RATE_API_KEY=

# ---- Transactional email (reminders) ----
RESEND_API_KEY=
